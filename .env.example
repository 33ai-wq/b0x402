# x402 Seller config
# chmod 600 after filling in

# REQUIRED: payout EOA address (receive-only, NEVER signs)
X402_PAYOUT_ADDRESS=

# REQUIRED (or use getpass at runtime): payout private key hex
# Keep this file chmod 600 and NEVER share
X402_PAYOUT_KEY_HEX=

# OPTIONAL: Fernet passphrase for encrypted keystore (min 16 chars)
X402_MASTER_KMS_KEY=

# Server config
PORT=8080

# Dev mode: set to true to bypass payments (NEVER in production)
X402_BYPASS=false